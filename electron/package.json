{
  "name": "my-tools-desktop",
  "version": "1.0.0",
  "description": "Desktop wrapper for my_tools using Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "desktop",
    "tools"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.mytools.desktop",
    "productName": "MyTools",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "frontend/"
    ],
    "extraResources": [
      {
        "from": "resources/api.exe",
        "to": "api.exe"
      },
      {
        "from": "resources/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "resources/ffprobe.exe",
        "to": "ffprobe.exe"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
